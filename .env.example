# Porta em que a API vai rodar
PORT=3000

# String de conexão com o PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/universidade?schema=public"

# String de conexão com o banco de dados dedicado aos testes de integração.
# Deve apontar para um banco separado do principal, pois as tabelas são limpas a cada teste.
DATABASE_URL_TEST="postgresql://usuario:senha@localhost:5432/universidade_test?schema=public"

# Segredo usado para assinar e validar os tokens JWT
JWT_SECRET="troque-por-um-valor-seguro"
JWT_EXPIRES_IN="2h"
BCRYPT_SALT_ROUNDS=10
