generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  email String @id
  cpf   String @unique
  nome  String
  senha String
  role  String

  professor Professor?

  @@map("usuario")
}

model Professor {
  matricula     String  @id
  emailUsuario  String  @unique @map("email_usuario")
  especialidade String?
  titulacao     String?

  usuario Usuario @relation(fields: [emailUsuario], references: [email])

  @@map("professor")
}

model Curso {
  codigo   String @id
  nome     String @unique
  periodos Int

  disciplinas Disciplina[]

  @@map("curso")
}

model Disciplina {
  codigo       String @id
  codCurso     String @map("cod_curso")
  periodo      Int
  nome         String
  cargaHoraria Int    @map("carga_horaria")

  curso Curso @relation(fields: [codCurso], references: [codigo])

  // O nome da disciplina não pode se repetir dentro do mesmo curso.
  @@unique([codCurso, nome])
  @@map("disciplina")
}
