generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  email String @id
  cpf   String @unique
  nome  String
  senha String
  role  String

  professor Professor?

  @@map("usuario")
}

model Professor {
  matricula     String  @id
  emailUsuario  String  @unique @map("email_usuario")
  especialidade String?
  titulacao     String?

  usuario       Usuario        @relation(fields: [emailUsuario], references: [email])
  lecionamentos Lecionamento[]

  @@map("professor")
}

model Curso {
  codigo   String @id
  nome     String @unique
  periodos Int

  disciplinas Disciplina[]

  @@map("curso")
}

model Disciplina {
  codigo       String @id
  codCurso     String @map("cod_curso")
  periodo      Int
  nome         String
  cargaHoraria Int    @map("carga_horaria")

  curso         Curso          @relation(fields: [codCurso], references: [codigo])
  lecionamentos Lecionamento[]

  // O nome da disciplina não pode se repetir dentro do mesmo curso.
  @@unique([codCurso, nome])
  @@map("disciplina")
}

model Semestre {
  codigo   String @id
  ano      Int
  semestre Int

  lecionamentos Lecionamento[]

  @@map("semestre")
}

model Lecionamento {
  codigo        String @id
  codDisciplina String @map("cod_disciplina")
  matProfessor  String @map("mat_professor")
  codSemestre   String @map("cod_semestre")
  turno         String
  diaSemana     String @map("dia_semana")

  disciplina Disciplina @relation(fields: [codDisciplina], references: [codigo])
  professor  Professor  @relation(fields: [matProfessor], references: [matricula])
  semestre   Semestre   @relation(fields: [codSemestre], references: [codigo])

  @@map("lecionamento")
}
